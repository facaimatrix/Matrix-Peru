{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MatrixPro Peru",
  "version": "1.0.2",
  "identifier": "edu.purdue.liang.matrixpro",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MatrixPro Peru — Matrix Model Based Forest Growth Simulator",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["data/*"],
    "icon": [
      "icons/icon.ico",
      "icons/96x96.png"
    ]
  }
}
